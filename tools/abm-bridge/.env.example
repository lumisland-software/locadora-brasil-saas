# Página de relatório da ABM Protege.
ABM_PORTAL_URL=https://abmtecnologia.abmprotege.net/relatorios/rotas/

# URL de login. Pode ser igual à página de relatório quando o portal redireciona automaticamente.
ABM_LOGIN_URL=https://abmtecnologia.abmprotege.net/relatorios/rotas/

# Data do relatório no formato YYYY-MM-DD. Vazio = data atual no fuso do portal.
ABM_REPORT_DATE=

# ID ABM de um único veículo para teste. Vazio = todos os veículos visíveis no portal.
ABM_VEHICLE_ID=

# Tempos máximos em milissegundos.
ABM_LIVE_TIMEOUT_MS=15000
ABM_SESSION_CHECK_TIMEOUT_MS=30000
ABM_LOGIN_TIMEOUT_MS=90000

# Caminho do ficheiro gerado.
ABM_OUTPUT=./abm-snapshot.json

# O sync agendado usa modo headless.
ABM_HEADLESS=true

# Endpoint do Worker que recebe o snapshot após a recolha.
ABM_INGEST_URL=https://SEU-WORKER.workers.dev/api/integrations/abm/ingest

# Seletores opcionais, separados por vírgula, caso o formulário da ABM mude.
ABM_USERNAME_SELECTOR=
ABM_PASSWORD_SELECTOR=
ABM_SUBMIT_SELECTOR=

# Não grave utilizador, senha ou ABM_INGEST_TOKEN neste ficheiro.
# setup-autonomous.ps1 guarda esses valores cifrados em .secrets/autonomous.bin.
